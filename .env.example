# ============================================================
# Lerno Microservices - Environment Variable Reference
# Copy this into each service's .env and fill in real values
# ============================================================

# --- General ---
PORT=3001                          # Change per service
NODE_ENV=development

# --- Database (Local PostgreSQL) ---
DATABASE_URL="postgresql://postgres:YOUR_PG_PASSWORD@localhost:5432/lerno_SERVICE_NAME?schema=public"

# --- Redis (Upstash - TLS Required) ---
# Get credentials from: https://console.upstash.com
REDIS_URL="rediss://default:YOUR_PASSWORD@YOUR_UPSTASH_ENDPOINT:6379"

# --- RabbitMQ (CloudAMQP - TLS Required) ---
# Get credentials from: https://www.cloudamqp.com/
RABBITMQ_URL="amqps://YOUR_USER:YOUR_PASSWORD@YOUR_HOSTNAME/YOUR_VHOST"

# --- JWT ---
JWT_ACCESS_SECRET="change-me-to-a-long-random-string"
JWT_REFRESH_SECRET="change-me-to-another-long-random-string"  # auth-service only

# --- Internal Communication ---
INTERNAL_SECRET="change-me-to-a-shared-internal-secret"

# --- PayHere (payment-service only) ---
PAYHERE_MERCHANT_ID="121XXXXX"
PAYHERE_MERCHANT_SECRET="your-payhere-sandbox-secret"
PAYHERE_MODE="sandbox"
